rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function isOwner(uid){ return signedIn() && request.auth.uid == uid; }
    function isAdmin(){ return signedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.active == true; }

    match /users/{uid} {
      allow create: if isOwner(uid) && request.resource.data.uid == request.auth.uid && request.resource.data.email == request.auth.token.email && request.resource.data.status == "active";
      allow read: if isOwner(uid) || isAdmin();
      allow update: if (isOwner(uid) && request.resource.data.uid == resource.data.uid && request.resource.data.email == resource.data.email && request.resource.data.status == resource.data.status) || isAdmin();
      allow delete: if isAdmin();
    }
    match /projects/{id}{ allow read: if resource.data.active == true || isAdmin(); allow write: if isAdmin(); }
    match /packages/{id}{ allow read: if resource.data.active == true || isAdmin(); allow write: if isAdmin(); }
    match /quote_questions/{id}{ allow read: if resource.data.active == true || isAdmin(); allow write: if isAdmin(); }
    match /quote_rules/{id}{ allow read: if resource.data.enabled == true || isAdmin(); allow write: if isAdmin(); }
    match /quotes/{id}{ allow create: if request.resource.data.status == "new"; allow read,update,delete: if isAdmin(); }
    match /contacts/{id}{ allow create: if request.resource.data.status == "new"; allow read,update,delete: if isAdmin(); }
    match /chat_sessions/{sid}{ allow create,update,read: if true; match /messages/{mid}{ allow create,read: if true; allow update,delete: if isAdmin(); } }
    match /managed_sites/{id}{ allow read: if isAdmin(); allow write: if false; }
    match /managed_site_secrets/{id}{ allow read,write: if false; }
    match /site_events/{id}{ allow read: if isAdmin(); allow write: if false; }
    match /site_settings/{id}{ allow read: if resource.data.active == true || isAdmin(); allow write: if isAdmin(); }
    match /admin_users/{uid}{ allow read: if isOwner(uid) || isAdmin(); allow write: if false; }
  }
}
